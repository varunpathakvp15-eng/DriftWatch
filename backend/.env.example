# Driftwatch - Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ─── Caseworker Model Backend ───
# Which model backend the AI caseworker uses:
#   openai      → GPT-4o (large closed model)
#   ollama_api  → Llama 3.1 8B via Ollama API (open-source)
#   ollama_local→ Llama 3.1 quantized GGUF via local Ollama
#   rule_based  → deterministic rules, no LLM (default)
CASEWORKER_MODEL_BACKEND=rule_based

# ─── LLM API keys ───
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Ollama configuration ───
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_MODEL=llama3.1:8b
OLLAMA_LOCAL_MODEL=llama3.1:8b-instruct-q4_K_M

# ─── Simulation configuration ───
TIER1_AGENT_COUNT=10000
TIER2_AGENT_COUNT=400
TIER3_AGENT_COUNT=100
SIMULATION_DAYS=30

# ─── Database ───
DATABASE_URL=postgresql://user:dbpass@localhost:5432/driftwatch
# For local dev without PostgreSQL:
# DATABASE_URL=sqlite:///./driftwatch.db

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── Server configuration ───
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ─── CORS (comma-separated allowed origins) ───
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# ─── Rate limiting ───
RATE_LIMIT_SIMULATIONS_PER_MINUTE=5
RATE_LIMIT_QUERIES_PER_MINUTE=30
